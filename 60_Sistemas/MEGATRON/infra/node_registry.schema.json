{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MEGATRON Node Registry",
  "type": "object",
  "required": ["version", "updated_at", "policy", "nodes"],
  "properties": {
    "version": { "type": "string" },
    "updated_at": { "type": "string" },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "status", "host", "priority", "capabilities", "services", "limits"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "role": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "target", "future", "disabled"] },
          "host": { "type": "string" },
          "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
          "hardware_profile": {
            "type": "object",
            "additionalProperties": true
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "services": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "protocol", "endpoint", "health", "data_classes"],
              "properties": {
                "name": { "type": "string" },
                "protocol": { "type": "string" },
                "endpoint": { "type": "string" },
                "health": { "type": "string" },
                "data_classes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": true
            }
          },
          "limits": {
            "type": "object",
            "required": ["gpu_required", "twenty_four_seven"],
            "properties": {
              "gpu_required": { "type": "boolean" },
              "twenty_four_seven": { "type": "boolean" },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
