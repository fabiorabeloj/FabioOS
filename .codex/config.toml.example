# Codex — exemplo de configuração de MCP servers do FabioOS.
# COPIE este arquivo para `.codex/config.toml` e preencha os tokens reais.
# O arquivo real (config.toml) está no .gitignore e NUNCA deve ser commitado.

[mcp_servers.n8n-docs]
command = "n8n-mcp"

[mcp_servers.n8n-docs.env]
MCP_MODE = "stdio"
LOG_LEVEL = "error"
DISABLE_CONSOLE_OUTPUT = "true"

[mcp_servers.n8n-mcp]
url = "http://localhost:5678/mcp-server/http"

[mcp_servers.n8n-mcp.http_headers]
Authorization = "Bearer <COLOQUE_SEU_TOKEN_N8N_MCP_AQUI>"

[mcp_servers.obsidian]
url = "https://127.0.0.1:27124/mcp/"

[mcp_servers.obsidian.http_headers]
Authorization = "Bearer <COLOQUE_SEU_TOKEN_OBSIDIAN_AQUI>"
