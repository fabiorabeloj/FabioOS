# MEGATRON Orchestrator - config local
# Copie para megatron.local.env (gitignored via .env.*)

# Interface principal (Agentarium)
AGENTARIUM_PORT=3847
AGENTARIUM_UI_PORT=5174
WHATSAPP_REPLY_TO_FABIO=true
WHATSAPP_CONVERSATIONAL=true
MEGATRON_OPENROUTER_MODEL=openrouter/free

# WhatsApp / Evolution (preencher numero em megatron.local.env)
FABIO_WHATSAPP_NUMBER=
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_INSTANCE=fabioos-pessoal

# Servicos locais
N8N_URL=http://localhost:5678
OPENCLAW_URL=http://127.0.0.1:18789

# Orquestracao (true/false)
MEGATRON_WAIT_SERVICES=true
MEGATRON_OPEN_BROWSER=true
MEGATRON_WITH_OPENCLAW=true
MEGATRON_WITH_WHATSAPP=true
MEGATRON_WITH_N8N_SYNC=true
MEGATRON_WITH_MAESTRO_WATCH=true
MEGATRON_WITH_INTAKE_WARM=true
